{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": ["OPENAI_API_KEY", "SUPABASE_SERVICE_ROLE_KEY", "ROOT_DOMAIN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {},
    "test": {
      "outputs": ["coverage/**"]
    }
  }
}
